# Copy this file to `.env` and uncomment or adjust the values you need.

# Django application settings

# Disable debug in normal use.
# DJANGO_DEBUG=0

# Allowed hostnames/IPs for accessing this web UI.
# Localhost only:
# DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,[::1]
#
# Example LAN access:
# DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,192.168.1.50

# Trust X-Forwarded-Host only if you run behind a reverse proxy that sets it correctly.
# DJANGO_USE_X_FORWARDED_HOST=0

# Enable HTTPS redirect only when TLS is terminated correctly in front of Django.
# DJANGO_SECURE_SSL_REDIRECT=0

# Mark cookies secure only when the app is served over HTTPS.
# DJANGO_SESSION_COOKIE_SECURE=0
# DJANGO_CSRF_COOKIE_SECURE=0


# AMP connection restrictions

# Restrict which AMP hosts this app is allowed to connect to.
# If AMP is local:
# AMP_ALLOWED_HOSTS=127.0.0.1,localhost
#
# Example AMP on another LAN host:
# AMP_ALLOWED_HOSTS=192.168.1.10


# OpenWrt RPC restrictions

# Restrict which OpenWrt hosts this app is allowed to connect to.
# Example:
# OPENWRT_ALLOWED_HOSTS=192.168.1.1


# Firewall execution settings

# Set to 0 for dry-run mode. Set to 1 to allow real firewall changes.
# FIREWALL_EXECUTE=1

# Maximum seconds allowed for local iptables/ufw commands.
# FIREWALL_COMMAND_TIMEOUT=10


# Example profiles

# 1. Localhost-only
# DJANGO_DEBUG=0
# DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,[::1]
# AMP_ALLOWED_HOSTS=127.0.0.1,localhost
# OPENWRT_ALLOWED_HOSTS=
# FIREWALL_COMMAND_TIMEOUT=10

# 2. LAN access with AMP on another host
# DJANGO_DEBUG=0
# DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,192.168.1.50
# AMP_ALLOWED_HOSTS=192.168.1.10
# OPENWRT_ALLOWED_HOSTS=
# FIREWALL_COMMAND_TIMEOUT=10

# 3. LAN access with OpenWrt enabled
# DJANGO_DEBUG=0
# DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,192.168.1.50
# AMP_ALLOWED_HOSTS=192.168.1.10
# OPENWRT_ALLOWED_HOSTS=192.168.1.1
# FIREWALL_COMMAND_TIMEOUT=10
